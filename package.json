{
  "name": "hm-lib",
  "version": "0.0.0",
  "private": true,
  "description": "HostingMaster Library",
  "repository": {
    "type": "git",
    "url": "https://github.com/hosting-master/hm-lib.git"
  },
  "scripts": {
    "release": "semantic-release"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "semantic-release": "^24.0.0"
  },
  "release": {
    "branches": ["main"],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      ["@semantic-release/changelog", {
        "changelogFile": "CHANGELOG.md"
      }],
      ["@semantic-release/exec", {
        "prepareCmd": "echo ${nextRelease.version} > VERSION && sed -i 's/go 1.26/go ${nextRelease.version}/' go.mod"
      }],
      ["@semantic-release/git", {
        "assets": ["CHANGELOG.md", "VERSION", "go.mod", "package.json"],
        "message": "chore(release): ${nextRelease.version} [skip ci]"
      }]
    ],
    "commit-analyzer": {
      "preset": "conventionalcommits"
    },
    "release-notes-generator": {
      "preset": "conventionalcommits"
    }
  }
}
